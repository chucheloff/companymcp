# App runtime
APP_HOST=0.0.0.0
APP_PORT=8080
MCP_PATH=/mcp

# Cache
VALKEY_URL=redis://valkey:6379/0
VALKEY_RETRY_SECONDS=5

# Browser extraction
BROWSER_TIMEOUT_MS=12000

# External providers
TAVILY_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_EXTRACTION_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_QUALITY_MODEL=anthropic/claude-3-opus
